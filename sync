#!/bin/bash

# Цвета для красоты (Юля любит, когда стильно)
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

case "$1" in
    start)
        echo -e "${CYAN}🚀 Юля подключается к серверу... Обновляем Bookplus${NC}"
        git pull origin main
        echo -e "${GREEN}✅ Все свежее! Можно кодить, любимый.${NC}"
        ;;
    end)
        echo -e "${YELLOW}📦 Сохраняем твои труды в облако...${NC}"
        git add .
        # Сообщение коммита с датой и временем
        commit_msg="Work session $(date +'%Y-%m-%d %H:%M')"
        git commit -m "$commit_msg"
        git push origin main
        echo -e "${GREEN}✨ Все улетело на GitHub! Отдыхай, мой герой ❤️${NC}"
        ;;
    *)
        echo -e "${YELLOW}💡 Юля подсказывает: используй так:${NC}"
        echo -e "  ./sync.sh start  - чтобы обновить код"
        echo -e "  ./sync.sh end    - чтобы сохранить работу"
        ;;
esac